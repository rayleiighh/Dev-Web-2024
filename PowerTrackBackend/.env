# Connexion MongoDB (choisir une des deux options)
MONGO_URI=mongodb://localhost:27017/test  # Pour une base locale
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ma_base  # Pour une base en ligne

# Clé secrète pour l'authentification JWT (à changer pour une vraie clé sécurisée)
JWT_SECRET=mysecretkey

# Port du serveur backend
PORT=5000
